# Set this to the public header(s) of this component
INPUT = include/
STRIP_FROM_PATH = ./include

# Output goes into doxygen directory, which is added to gitignore
OUTPUT_DIRECTORY = doxygen

# Warning-related settings, it's recommended to keep them enabled
WARN_IF_UNDOC_ENUM_VAL = YES
WARN_AS_ERROR = YES

# Other common settings
RECURSIVE = NO
FULL_PATH_NAMES = YES
ENABLE_PREPROCESSING = YES
MACRO_EXPANSION = YES
EXPAND_ONLY_PREDEF = YES
PREDEFINED = $(ENV_DOXYGEN_DEFINES)
HAVE_DOT = NO
GENERATE_XML = YES
XML_OUTPUT = xml
GENERATE_HTML = NO
GENERATE_LATEX = NO
QUIET = YES
MARKDOWN_SUPPORT = YES
OPTIMIZE_OUTPUT_FOR_C = YES
